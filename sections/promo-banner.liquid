<section class="section">
  <div class="container">
    <div class="promo-banner">
      <div class="promo-banner__content">
        {% if section.settings.eyebrow != blank %}
          <div style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.65);margin-bottom:10px;">{{ section.settings.eyebrow }}</div>
        {% endif %}
        <h2>{{ section.settings.heading | default: 'Charge Smarter, Not Harder' }}</h2>
        <p style="margin-top:10px;margin-bottom:28px;">{{ section.settings.subheading | default: 'Upgrade your charging setup with our best-selling GaN technology. Smaller, faster, cooler.' }}</p>
        {% if section.settings.btn_label != blank %}
          <a href="{{ section.settings.btn_url | default: routes.all_products_collection_url }}" class="btn btn--accent btn--lg">
            {{ section.settings.btn_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "LIMITED TIME OFFER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Charge Smarter, Not Harder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Upgrade your charging setup with our best-selling GaN technology. Smaller, faster, cooler."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Shop GaN Chargers →"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
