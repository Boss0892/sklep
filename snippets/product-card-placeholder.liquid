{% comment %}
  Placeholder product card used before a collection is connected.
  Accepts: title, price (cents), compare_at_price (cents), badge, category, emoji, rating, review_count
{% endcomment %}

{%- assign on_sale = false -%}
{%- if compare_at_price > 0 and compare_at_price > price -%}
  {%- assign on_sale = true -%}
{%- endif -%}

<div class="product-card" data-category="{{ category | handleize }}" data-price="{{ price | divided_by: 100.0 }}">
  <div class="product-card__media">
    <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:4.5rem;" aria-hidden="true">{{ emoji }}</div>

    {% if badge != blank %}
      <span class="product-badge product-badge--{{ badge }}">
        {%- case badge -%}
          {%- when 'new' -%}New
          {%- when 'sale' -%}Sale
          {%- when 'hot' -%}Hot
          {%- when 'best' -%}Bestseller
        {%- endcase -%}
      </span>
    {% endif %}

    <button class="product-card__wishlist" aria-label="Add to wishlist">♡</button>
  </div>

  <div class="product-card__body">
    <div class="product-card__vendor">{{ category }}</div>
    <div class="product-card__title">{{ title }}</div>
    <div class="product-card__rating">
      <span class="product-card__stars" aria-hidden="true">★★★★★</span>
      <span class="product-card__review-count">({{ review_count }})</span>
    </div>
    <div class="product-card__price-row">
      <span class="product-card__price{% if on_sale %} product-card__price--sale{% endif %}">
        ${{ price | divided_by: 100.0 | round: 2 }}
      </span>
      {% if on_sale %}
        <span class="product-card__price-compare">${{ compare_at_price | divided_by: 100.0 | round: 2 }}</span>
        <span class="product-card__save">
          Save {{ compare_at_price | minus: price | times: 100 | divided_by: compare_at_price | round }}%
        </span>
      {% endif %}
    </div>
  </div>

  <div class="product-card__footer">
    <button class="btn--add-to-cart" aria-label="Add {{ title }} to cart">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Add to Cart
    </button>
  </div>
</div>
